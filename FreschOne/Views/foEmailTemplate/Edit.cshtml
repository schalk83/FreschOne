@model FreschOne.Models.foEmailTemplate
@{
    ViewData["Title"] = "Edit Email Template";
    var userid = ViewBag.userid;
}
<partial name="_Sidebar" />
<h2>Edit Email Template</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ID" />
    <input type="hidden" name="userid" value="@userid" />

    <div class="form-group">
        <label>Template Type</label>
        <select asp-for="TemplateType" class="form-control" asp-items="new SelectList(ViewBag.TemplateTypes)">
            <option value="">-- Select Type --</option>
        </select>
    </div>

    <div class="form-group">
        <label>Email Subject</label>
        <input asp-for="EmailSubject" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email Body</label>
        <textarea asp-for="EmailBody" class="form-control" rows="6"></textarea>
    </div>
    <div class="form-group form-check">
        <input asp-for="Active" class="form-check-input" type="checkbox" />
        <label class="form-check-label" asp-for="Active">Active</label>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-dark">Update</button>
        <a asp-action="Index" asp-route-userid="@userid" class="btn btn-secondary">Cancel</a>
    </div>
</form>
